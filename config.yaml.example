# ============================================================
# EV Car Alert Scraper - Configuration
# Edit this file to customise your searches and notifications
# ============================================================

# --- Email Settings ---
email:
  smtp_host: "smtp.gmail.com"        # or smtp.office365.com, your own server, etc.
  smtp_port: 587
  smtp_user: "you@gmail.com"         # sender address
  smtp_password: "your_app_password" # Gmail: use App Password not account password
  to: "you@youremail.com"            # where to send the digest
  subject_prefix: "🚗 EV Alert"

# --- Search Defaults ---
# These apply to every search unless overridden in the individual search block.
defaults:
  postcode: "EH1 3HU"      # your postcode for distance calculations
  radius: 120               # miles
  fuel_type: "Electric"
  year_from: 2021
  mileage_max: 110000

# --- Resource Limits (tune for your Proxmox server) ---
limits:
  max_concurrent_pages: 3      # AutoTrader listing detail pages scraped simultaneously.
                               # ~3x faster listing scrape, ~90MB extra RAM per tab.
                               # Safe: LXC has 8GB host / 4 CPUs with headroom to spare.
  page_timeout_ms: 30000       # 30s per page load
  scroll_pause_ms: 1500        # pause between scrolls (be polite to sites)
  request_delay_ms: 3000       # pause between listings within a search
  search_delay_ms: 8000        # pause between different searches
  max_pages_per_search: 2      # fallback depth: if page 1 is all already-known, try page 2
  max_listings_per_search: 20  # the 20 cheapest matching listings per search (one page only)
  max_images_per_listing: 3    # images to embed in email per car
  max_email_listings: 20       # total car cards shown in the email (oldest excess → JSON only)

# --- Database ---
database:
  path: "/opt/ev-scraper/data/listings.db"

# --- Output ---
output:
  json_path: "/opt/ev-scraper/data/latest_results.json"
  log_path: "/opt/ev-scraper/logs/scraper.log"

# --- Searches ---
# Each search hits AutoTrader UK with your criteria.
# 'keywords' are matched against the title/spec Playwright sees on the page.
# Set 'enabled: false' to pause a search without deleting it.
# All autotrader fields are optional — missing ones fall back to 'defaults' above.
searches:

  - name: "Skoda Enyaq iV 80"
    enabled: true
    autotrader:
      make: "Skoda"
      model: "Enyaq"
      price_max: 22000
      radius: 200         # wider net — thin stock in Scotland
    # require_keywords left empty — spec_summary extraction is unreliable;
    # use exclude_keywords only until selector is verified working
    require_keywords: []
    # If ANY of these appear, listing is skipped
    exclude_keywords: ["iV 60", "60kWh", "vRS", "Coupe", "coupé", "Enyaq 60", "55kWh"]

  - name: "Kia EV6"
    enabled: true
    autotrader:
      make: "Kia"
      model: "EV6"
      price_max: 22000
      mileage_max: 70000  # slightly tighter than default — some PCO exposure
    require_keywords: []
    exclude_keywords: ["GT"]   # GT is rare and overpriced used

  - name: "Hyundai Ioniq 5"
    enabled: true
    autotrader:
      make: "Hyundai"
      model: "Ioniq 5"
      price_max: 20000
      mileage_max: 40000  # tighter than default — heavy Uber/PCO use in UK
    require_keywords: ["IONIQ 5"]  # prevents old Ioniq hatchback and unrelated models (Tucson etc)
    exclude_keywords: []

  - name: "VW ID.4"
    enabled: true
    autotrader:
      make: "Volkswagen"
      model: "ID.4"
      price_max: 20000
      radius: 200
    # require_keywords dropped — spec_summary unreliable; price filters Pro anyway
    require_keywords: ["ID.4"]  # prevents ID.3, VW up!, Transporter and other VW EVs leaking in
    exclude_keywords: ["ID.4 GTX"]  # AWD variant tends to be overpriced

  - name: "Kia EV3"
    enabled: true
    autotrader:
      make: "Kia"
      model: "EV3"
      price_max: 30000
      radius: 200
      year_from: 2025
      mileage_max: 20000  # only low-mileage ex-demo/early returns
    require_keywords: []
    # Note: 460L boot is smaller than ideal for 2 dogs — watch but don't exclude
    exclude_keywords: ["Standard Range"]  # want the 81kWh not the 58kWh

  - name: "Kia EV5 (Watch)"
    enabled: true
    autotrader:
      make: "Kia"
      model: "EV5"
      price_max: 33000
      radius: 200
      year_from: 2025
      mileage_max: 20000
    require_keywords: []
    exclude_keywords: []

  - name: "BMW iX3"
    enabled: true
    autotrader:
      make: "BMW"
      model: "iX3"
      price_max: 23000
    require_keywords: ["iX3"]  # prevents BMW i3 (city car) bleeding into results
    exclude_keywords: []

  - name: "BYD Sealion 7 (Watch)"
    enabled: true
    autotrader:
      make: "BYD"
      model: "Sealion 7"
      price_max: 26000
      radius: 300         # override — wider net for rarer model
      year_from: 2023
      mileage_max: 60000
    require_keywords: []
    exclude_keywords: []

  # --- Future models: these will return nothing until cars appear ---
  - name: "Skoda Peaq (Future Watch)"
    enabled: true
    autotrader:
      make: "Skoda"
      model: "Peaq"
      price_max: 40000
      radius: 300
      year_from: 2026
      mileage_max: 50000
    require_keywords: []
    exclude_keywords: []

  - name: "Kia PV5 7-seat (Future Watch)"
    enabled: true
    autotrader:
      make: "Kia"
      model: "PV5"
      price_max: 35000
      radius: 300
      year_from: 2026
      mileage_max: 50000
    require_keywords: []
    exclude_keywords: []

